{
  "name": "@chronogrove/ui",
  "version": "0.76.0",
  "description": "Chronogrove Theme UI theme, color mode helpers, and shared UI primitives",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
