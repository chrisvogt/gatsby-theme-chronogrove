{
  "name": "@chronogrove/ui",
  "version": "0.79.0",
  "description": "Chronogrove Theme UI theme, color mode helpers, and shared UI primitives",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisvogt/gatsby-theme-chronogrove.git",
    "directory": "packages/ui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./theme": {
      "import": "./src/theme.js",
      "default": "./src/theme.js"
    },
    "./provider": {
      "import": "./src/provider.js",
      "default": "./src/provider.js"
    },
    "./button": {
      "import": "./src/button.js",
      "default": "./src/button.js"
    },
    "./color-toggle": {
      "import": "./src/color-toggle.js",
      "default": "./src/color-toggle.js"
    },
    "./color-toggle-styles": "./src/color-toggle-styles.css",
    "./skip-nav": {
      "import": "./src/skip-nav/index.js",
      "default": "./src/skip-nav/index.js"
    },
    "./color-mode": {
      "import": "./src/color-mode/index.js",
      "default": "./src/color-mode/index.js"
    },
    "./emotion-cache": {
      "import": "./src/emotion-cache.js",
      "default": "./src/emotion-cache.js"
    },
    "./is-dark-mode": {
      "import": "./src/helpers/isDarkMode.js",
      "default": "./src/helpers/isDarkMode.js"
    },
    "./color-utils": {
      "import": "./src/color-utils.js",
      "default": "./src/color-utils.js"
    },
    "./action-button": {
      "import": "./src/action-button.js",
      "default": "./src/action-button.js"
    },
    "./pagination-button": {
      "import": "./src/pagination-button.js",
      "default": "./src/pagination-button.js"
    },
    "./lazy-load": {
      "import": "./src/lazy-load.js",
      "default": "./src/lazy-load.js"
    },
    "./next": {
      "import": "./src/next/index.js",
      "default": "./src/next/index.js"
    },
    "./header": {
      "import": "./src/header.js",
      "default": "./src/header.js"
    },
    "./page-header": {
      "import": "./src/page-header.js",
      "default": "./src/page-header.js"
    },
    "./page-backdrop": {
      "import": "./src/page-backdrop.js",
      "default": "./src/page-backdrop.js"
    },
    "./animated-page-background": {
      "import": "./src/animated-page-background/index.js",
      "default": "./src/animated-page-background/index.js"
    },
    "./color-bends": {
      "import": "./src/animated-page-background/ColorBends.js",
      "default": "./src/animated-page-background/ColorBends.js"
    },
    "./action-card-layout": {
      "import": "./src/action-card-layout.js",
      "default": "./src/action-card-layout.js"
    },
    "./gatsby": {
      "import": "./src/gatsby/index.js",
      "default": "./src/gatsby/index.js"
    }
  },
  "scripts": {
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage --colors"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@emotion/cache": "catalog:",
    "@emotion/react": "catalog:",
    "@theme-toggles/react": "catalog:",
    "@theme-ui/components": "catalog:",
    "@theme-ui/presets": "^0.17.4",
    "react-intersection-observer": "catalog:",
    "theme-ui": "catalog:",
    "three": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
