      "import": "./src/theme.js",
      "default": "./src/theme.js"
    },
    "./provider": {
      "import": "./src/provider.js",
      "default": "./src/provider.js"
    },
    "./button": {
      "import": "./src/button.js",
      "default": "./src/button.js"
    },
    "./color-toggle": {
      "import": "./src/color-toggle.js",
      "default": "./src/color-toggle.js"
    },
    "./skip-nav": {
      "import": "./src/skip-nav/index.js",
      "default": "./src/skip-nav/index.js"
    },
    "./color-mode": {
      "import": "./src/color-mode/index.js",
      "default": "./src/color-mode/index.js"
