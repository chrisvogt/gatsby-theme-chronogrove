{
  "private": true,
  "scripts": {
    "develop": "pnpm run develop:website",
    "develop:theme": "pnpm --filter www.chronogrove.com develop",
    "develop:website": "pnpm --filter www.chrisvogt.me develop:https",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node ./scripts/postinstall-banner.js",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "pnpm --filter gatsby-theme-chronogrove test:watch",
    "build": "turbo run build"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "only-allow": "^1.1.1",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "lodash": "^4.17.23"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23"
    }
  },
  "packageManager": "pnpm@9.15.0"
}
