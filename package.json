{
  "private": true,
  "scripts": {
    "develop": "pnpm run develop:website",
    "develop:theme": "pnpm --filter www.chronogrove.com develop",
    "develop:website": "pnpm --filter www.chrisvogt.me develop:https",
    "develop:next": "pnpm --filter chronogrove-next dev",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node ./packages/theme/scripts/postinstall-banner.mjs",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "test": "turbo run test --concurrency=1",
    "test:coverage": "turbo run test:coverage --concurrency=1",
    "test:watch": "pnpm --filter gatsby-theme-chronogrove test:watch",
    "build": "turbo run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "catalog:",
    "pretty-quick": "^4.2.2",
    "turbo": "^2.9.16"
  },
  "dependencies": {
    "boxen": "catalog:",
    "chalk": "^4.1.2",
    "lodash": "^4.18.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1",
      "@mdx-js/react": "^3.1.1",
      "multer": "^2.1.1",
      "serialize-javascript": ">=7.0.3",
      "flatted": "^3.4.2",
      "socket.io-parser": "^4.2.6",
      "immutable": "^3.8.3",
      "svgo": "^2.8.1",
      "gatsby-plugin-google-analytics>minimatch": "^3.1.4",
      "gatsby-plugin-sitemap>minimatch": "^3.1.4",
      "path-to-regexp": ">=0.1.13 <0.2.0"
    },
    "publicHoistPattern": [
      "*"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "core-js-pure",
      "gatsby",
      "gatsby-cli",
      "lmdb",
      "lottie-react-web",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  }
}
