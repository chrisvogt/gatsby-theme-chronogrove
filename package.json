{
  "private": true,
  "scripts": {
    "develop": "pnpm run develop:website",
    "develop:theme": "pnpm --filter www.chronogrove.com develop",
    "develop:website": "pnpm --filter www.chrisvogt.me develop:https",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node ./scripts/postinstall-banner.mjs",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "pnpm --filter gatsby-theme-chronogrove test:watch",
    "build": "turbo run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "turbo": "^2.8.20"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "lodash": "^4.17.23"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23",
      "@mdx-js/react": "^3.1.1",
      "multer": "^2.1.0",
      "serialize-javascript": ">=7.0.3",
      "gatsby-plugin-google-analytics>minimatch": "^3.1.4",
      "gatsby-plugin-sitemap>minimatch": "^3.1.4"
    },
    "publicHoistPattern": [
      "*"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js-pure",
      "es5-ext",
      "gatsby",
      "gatsby-cli",
      "lmdb",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  }
}
