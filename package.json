{
  "private": true,
  "scripts": {
    "develop": "pnpm run develop:website",
    "develop:theme": "pnpm --filter www.chronogrove.com develop",
    "develop:website": "pnpm --filter www.chrisvogt.me develop:https",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx}\"",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node ./scripts/postinstall-banner.js",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "pnpm --filter gatsby-theme-chronogrove test:watch",
    "build": "turbo run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "turbo": "^2.8.12"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "lodash": "^4.17.23"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23",
      "@mdx-js/react": "^3.1.1"
    },
    "publicHoistPattern": [
      "*"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js-pure",
      "es5-ext",
      "gatsby",
      "gatsby-cli",
      "lmdb",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix"
  }
}
